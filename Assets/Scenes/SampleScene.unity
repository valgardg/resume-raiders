      m_Calls: []
  m_text: "You work as an outsourced talent hiring manager who helps companies find
    the perfect applicant for their completely valid job postings! \n\nEvery day
    you have to find a certian number of suitable candidates for your client company,
    ensuring that the applicant has the required traits that the job requires, while
    also not having any undesired traits.\n\nThe trait sheet helps you know what
    traits are available, as well as what each trait means.\n\nIf you fail to find
    the amount of candidates that the company wants, you will be fired, so dont fail!\n\nP.S,
    you work between 9am and 5pm ;)"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
